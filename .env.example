# ---- Copy this file to ".env" and fill in real values ----

# PostgreSQL connection
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/boiler_db

# Flask
SECRET_KEY=change-this-to-a-long-random-string

# Outgoing mail (Gmail example — see README for the "dummy test mailbox" steps)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your.test.mailbox@gmail.com
SENDER_APP_PASSWORD=xxxxxxxxxxxxxxxx
ADMIN_EMAIL=your.test.mailbox@gmail.com

# Google reCAPTCHA v2 ("I'm not a robot" checkbox)
# Get these from https://www.google.com/recaptcha/admin/create
RECAPTCHA_SITE_KEY=your-site-key
RECAPTCHA_SECRET_KEY=your-secret-key
